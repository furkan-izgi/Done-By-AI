{
  "manifest_version": 3,
  "name": "Time Keeper Pro",
  "version": "2.1",
  "description": "Web sitelerinde geçirdiğin süreyi takip et ve özel sesli uyarılar kur.",
  "permissions": ["storage"],
  "host_permissions": ["*://*.youtube.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.svg"
  },
  "icons": {
    "128": "icon.svg"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content_script.js"],
      "run_at": "document_idle"
    }
  ]
}